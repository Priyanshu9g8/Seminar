spring.application.name=GyanSetu
server.port=8080

# ================= DATABASE =================
# Replace with your local/prod DB settings
spring.datasource.url=jdbc:mysql://localhost:3306/gyan_setu
spring.datasource.username=root
spring.datasource.password=YOUR_PASSWORD_HERE

spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ================= JPA =================
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

# ================= JWT =================
# Use a long random string for production!
app.jwt.secret=REPLACE_WITH_YOUR_SECRET_KEY
app.jwt.expiration-millis=31536000000

# ================= CORS =================
app.cors.allowed-origins=http://localhost:5173

# ================= GOOGLE AI =================
# Get your key from https://aistudio.google.com/
google.api.key=YOUR_GOOGLE_AI_KEY
